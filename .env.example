APP_NAME=PulseWatch
APP_ENV=development
DATABASE_URL=postgresql://pulsewatch_user:pulsewatch_pass@localhost:5432/pulsewatch_db
POSTGRES_USER=pulsewatch_user
POSTGRES_PASSWORD=pulsewatch_pass
POSTGRES_DB=pulsewatch_db
JWT_SECRET_KEY=change-me
JWT_EXPIRE_MINUTES=60
ENABLE_SCHEDULER=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
EXPORT_DIR=exports
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
SLACK_WEBHOOK_URL=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=
